{
  "schemaVersion": 1,
  "id": "krepapi",
  "version": "${version}",
  "name": "KrepAPI",
  "description": "Client API for server-driven key bindings, raw key and mouse events, and optional mod requirement checks. This build targets Minecraft 1.21.4–1.21.11. For Minecraft 26.1+ use the KrepAPI-mc26.1 JAR from the same release.",
  "authors": [
    "shik"
  ],
  "contact": {
    "homepage": "https://github.com/RafaelK-F/KrepAPI",
    "issues": "https://github.com/RafaelK-F/KrepAPI/issues"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.github": "https://github.com/RafaelK-F/KrepAPI"
      },
      "update_checker": true
    }
  },
  "license": "All-Rights-Reserved",
  "accessWidener": "krepapi.accesswidener",
  "icon": "assets/krepapi/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "net.shik.krepapi.client.KrepapiDataGenerator"
    ],
    "client": [
      "net.shik.krepapi.Krepapi"
    ],
    "main": [
      "net.shik.krepapi.Krepapi"
    ],
    "modmenu": [
      "net.shik.krepapi.KrepapiModMenuEntry"
    ]
  },
  "mixins": [
    "krepapi.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version_range}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
