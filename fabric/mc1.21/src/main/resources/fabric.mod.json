{
  "schemaVersion": 1,
  "id": "krepapi",
  "version": "${version}",
  "name": "KrepAPI",
  "description": "Client API for server-driven key bindings, raw key and mouse events, and optional mod requirement checks. This build targets Minecraft 1.21.4–1.21.11. For Minecraft 26.1+ use the KrepAPI-mc26.1 JAR from the same release.",
  "authors": [
    "shik"
  ],
  "contact": {},
  "license": "All-Rights-Reserved",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "net.shik.krepapi.client.KrepapiDataGenerator"
    ],
    "client": [
      "net.shik.krepapi.client.KrepapiClient"
    ],
    "main": [
      "net.shik.krepapi.Krepapi"
    ]
  },
  "mixins": [
    "krepapi.mixins.json",
    {
      "config": "krepapi.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version_range}"
  }
}
